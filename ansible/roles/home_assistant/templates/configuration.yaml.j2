# Managed by Ansible. Do not edit manually — changes will be overwritten.
# Loads default set of integrations. Do not remove.
default_config:

http:
  use_x_forwarded_for: true
  trusted_proxies:
    - {{ hostvars['norville']['ip_address'] }}

# Load frontend themes from the themes folder
frontend:
  themes: !include_dir_merge_named /themes
  extra_module_url:
    - /hacsfiles/lovelace-card-mod/card-mod.js?hacstag=190927524421

sensor:
  - platform: time_date
    display_options:
      - "time"
      - "date"
      - "date_time"
      - "date_time_utc"
      - "date_time_iso"
      - "time_date"
      - "time_utc"

template:
  - sensor:
      - name: Next Bin Collection
        state: "{% raw %}{{ now().date() }}{% endraw %}"

config_editor:

logger:
  default: warn
  logs:
    custom_components.midea_ac_lan: debug
    midealocal: debug

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml
